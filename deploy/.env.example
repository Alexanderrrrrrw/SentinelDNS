# ─── Sentinel DNS — Environment Configuration ───
#
# Copy this file to .env and customize:
#   cp .env.example .env
#
# Then deploy:
#   docker compose up -d --build

# ─── Security ───

# Admin token for all protected API endpoints.
# CHANGE THIS to a long random string before deploying.
SENTINEL_ADMIN_TOKEN=changeme-to-a-long-random-string

# Set to true to refuse starting if no admin token is set.
SENTINEL_REQUIRE_AUTH=true

# ─── DNS ───

# How to respond to blocked domains:
#   nxdomain — respond with NXDOMAIN (domain does not exist)
#   null_ip  — respond with 0.0.0.0
SENTINEL_BLOCK_MODE=nxdomain

# Encrypted upstream DNS (optional). Leave empty for system default (plain DNS).
# Examples:
#   tls://1.1.1.1:853#cloudflare-dns.com          (DNS-over-TLS to Cloudflare)
#   tls://9.9.9.9:853#dns.quad9.net                (DNS-over-TLS to Quad9)
#   https://1.1.1.1:443#cloudflare-dns.com         (DNS-over-HTTPS to Cloudflare)
SENTINEL_UPSTREAM=

# ─── Heuristics ───

# Enable/disable the heuristic domain scoring engine.
# When enabled, domains scoring >= 70 are auto-blocked even without a blocklist match.
SENTINEL_HEURISTICS=true

# ─── Gravity ───

# How often to automatically re-fetch blocklists (in seconds).
# Default: 604800 (1 week). Set to 0 to disable auto-updates.
SENTINEL_GRAVITY_INTERVAL_SECS=604800

# ─── RAM-First Log Pipeline (SD card protection) ───

# Max DNS log records held in RAM before oldest are evicted.
# Higher = more history visible before checkpoint, but uses more memory.
# On a 4 GB Pi, 100k records ≈ 30 MB of RAM.
SENTINEL_RAM_LOG_CAPACITY=100000

# How often to flush the RAM buffer to DuckDB on disk (in seconds).
# Default: 900 (15 minutes). Lower = more disk writes, higher = more data at risk.
SENTINEL_CHECKPOINT_SECS=900

# Maximum records to write in a single checkpoint batch.
SENTINEL_CHECKPOINT_BATCH=50000

# ─── Logging ───

# Rust log level. Options: error, warn, info, debug, trace
RUST_LOG=info
